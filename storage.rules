rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /items/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Fallback for other paths if needed
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
